APP_NAME=incidentmemory-enterprise-rag
APP_ENV=dev
LOG_LEVEL=INFO
API_PORT=8000
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/incidentmemory
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=incident_chunks
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
TOP_K=10
RERANK_TOP_N=5
